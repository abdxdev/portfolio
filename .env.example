# Admin password for accessing feedback responses
ADMIN_PASSWORD=your-secure-password-here

# Supabase for storing conversations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-service-role-key-here

# OneSignal for push notifications
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
NEXT_PUBLIC_ONESIGNAL_SAFARI_WEB_ID=your-onesignal-safari-web-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# GitHub for triggering workflows
GITHUB_TOKEN=your-github-token-here

# Resend for sending email notifications
RESEND_API_KEY=your-resend-api-key-here